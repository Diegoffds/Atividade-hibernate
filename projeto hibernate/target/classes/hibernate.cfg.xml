<!DOCTYPE hibernate-configuration PUBLIC
"-//Hibernate/Hibernate Configuration DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <!-- Conexão com MySQL -->
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/es2</property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password">01022006d</property>

        <!-- Dialeto -->
        <property name="hibernate.dialect">org.hibernate.dialect.MySQLDialect</property>

        <!-- Mostrar SQL -->
        <property name="hibernate.show_sql">true</property>

        <!-- Criar tabelas automático -->
        
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- Suas classes -->
        <mapping class="Classes.Item"/>
        <mapping class="Classes.Pedido"/>
        <mapping class="Classes.Produto"/>
        <mapping class="Classes.ProdutoEletronico"/>
        <mapping class="Classes.ProdutoPerecivel"/>

    </session-factory>
</hibernate-configuration>